###
# GPS Attendance Tracker - Backend Test Hub (HTTP REST Client)
# Author: borakport
# Updated: 2025-08-28 UTC
# 
# Instructions:
# 1. Install REST Client extension in VS Code
# 2. Click "Send Request" above each request
# 3. Copy tokens from responses to use in subsequent requests
# 4. NO ACCESS CODES NEEDED - GPS verification only!

### Variables
@baseUrl = http://localhost
@authApi = {{baseUrl}}:3001/api/v1/auth
@attendanceApi = {{baseUrl}}:3002/api/v1
@realtimeUrl = {{baseUrl}}:3003

# Tokens (update these after signing in)
@instructorToken = YOUR_INSTRUCTOR_TOKEN_HERE
@studentToken = YOUR_STUDENT_TOKEN_HERE
@adminToken = YOUR_ADMIN_TOKEN_HERE

# Test IDs (update these as you create resources)
@courseId = YOUR_COURSE_ID_HERE
@sessionId = YOUR_SESSION_ID_HERE

###############################################################################
# 1. SERVICE HEALTH CHECKS
###############################################################################

### Check Auth Service Health
GET {{authApi}}/../../health
Content-Type: application/json

### Check Attendance Service Health  
GET {{attendanceApi}}/../../health
Content-Type: application/json

### Check Realtime Service (Open in browser)
# Open: {{realtimeUrl}}

###############################################################################
# 2. AUTHENTICATION TESTS
###############################################################################

### Sign in as Instructor
POST {{authApi}}/signin
Content-Type: application/json

{
  "email": "instructor@attendance.com",
  "password": "Instructor@123"
}

### Sign in as Student
POST {{authApi}}/signin
Content-Type: application/json

{
  "email": "student1@attendance.com",
  "password": "Student@123"
}

### Sign in as Admin
POST {{authApi}}/signin
Content-Type: application/json

{
  "email": "admin@attendance.com",
  "password": "Admin@123"
}

### Sign up new user
POST {{authApi}}/signup
Content-Type: application/json

{
  "email": "newuser@test.com",
  "password": "NewUser@123",
  "confirmPassword": "NewUser@123",
  "firstName": "Test",
  "lastName": "User",
  "phoneNumber": "+1234567890"
}

### Get User Profile (Instructor)
GET {{authApi}}/profile
Authorization: Bearer {{instructorToken}}

### Get User Profile (Student)
GET {{authApi}}/profile
Authorization: Bearer {{studentToken}}

### Refresh Token
POST {{authApi}}/refresh
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

###############################################################################
# 3. COURSE MANAGEMENT TESTS
###############################################################################

### Get All Courses (Instructor)
GET {{attendanceApi}}/courses
Authorization: Bearer {{instructorToken}}

### Create New Course (Instructor)
POST {{attendanceApi}}/courses
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "name": "Test Course via HTTP",
  "description": "Test course created via REST Client",
  "startDate": "2025-08-29",
  "endDate": "2025-11-29",
  "settings": {
    "gpsRadius": 100,
    "allowLateEntry": true,
    "lateEntryMinutes": 15,
    "requireSelfie": false
  }
}

### Get Course by ID
GET {{attendanceApi}}/courses/{{courseId}}
Authorization: Bearer {{instructorToken}}

### Join Course (Student) - Using Course Code
POST {{attendanceApi}}/courses/join
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "code": "COURSE_CODE_HERE"
}

### Leave Course (Student)
DELETE {{attendanceApi}}/courses/{{courseId}}/leave
Authorization: Bearer {{studentToken}}

### Update Course (Instructor)
PUT {{attendanceApi}}/courses/{{courseId}}
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "name": "Updated Course Name",
  "description": "Updated description",
  "settings": {
    "gpsRadius": 150,
    "allowLateEntry": true,
    "lateEntryMinutes": 20,
    "requireSelfie": false
  }
}

### Get Course Members (Instructor)
GET {{attendanceApi}}/courses/{{courseId}}/members
Authorization: Bearer {{instructorToken}}

###############################################################################
# 4. SESSION MANAGEMENT TESTS
###############################################################################

### Get Active Sessions
GET {{attendanceApi}}/sessions/active
Authorization: Bearer {{instructorToken}}

### Create New Session (Instructor) - GPS ONLY, NO ACCESS CODE
POST {{attendanceApi}}/sessions
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "courseId": "{{courseId}}",
  "name": "HTTP Test Session",
  "description": "Test session from REST Client",
  "startTime": "2025-08-28T15:00:00Z",
  "endTime": "2025-08-28T17:00:00Z",
  "latitude": 37.7749,
  "longitude": -122.4194,
  "radiusMeters": 100,
  "locationName": "Test Location (GPS Only)",
  "allowLateEntry": true,
  "lateMinutes": 15,
  "requireSelfie": false
}

### Start Session (Instructor) - Triggers Real-time Events
POST {{attendanceApi}}/sessions/{{sessionId}}/start
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{}

### Get Session Details
GET {{attendanceApi}}/sessions/{{sessionId}}
Authorization: Bearer {{instructorToken}}

### End Session (Instructor)
POST {{attendanceApi}}/sessions/{{sessionId}}/end
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{}

### Get Session Statistics
GET {{attendanceApi}}/sessions/{{sessionId}}/stats
Authorization: Bearer {{instructorToken}}

###############################################################################
# 5. ATTENDANCE MARKING TESTS (GPS ONLY)
###############################################################################

### Mark Attendance - Within GPS Range (Should Succeed + Trigger Real-time Event)
POST {{attendanceApi}}/attendance/mark
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "sessionId": "{{sessionId}}",
  "latitude": 37.7749,
  "longitude": -122.4194,
  "deviceInfo": {
    "platform": "web",
    "model": "REST Client",
    "osVersion": "Windows 11",
    "appVersion": "1.0.0"
  }
}

### Mark Attendance - Outside GPS Range (Should Fail)
POST {{attendanceApi}}/attendance/mark
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "sessionId": "{{sessionId}}",
  "latitude": 37.8000,
  "longitude": -122.4500,
  "deviceInfo": {
    "platform": "web",
    "model": "REST Client",
    "osVersion": "Windows 11",
    "appVersion": "1.0.0"
  }
}

### Get Session Attendance Report (Instructor)
GET {{attendanceApi}}/attendance/session/{{sessionId}}
Authorization: Bearer {{instructorToken}}

### Get My Attendance History (Student)
GET {{attendanceApi}}/attendance/my-history
Authorization: Bearer {{studentToken}}

### Get My Attendance for Specific Course (Student)
GET {{attendanceApi}}/attendance/my-history/{{courseId}}
Authorization: Bearer {{studentToken}}

### Update Attendance (Instructor) - Manual override
PUT {{attendanceApi}}/attendance/{{sessionId}}/update
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "userId": "USER_ID_HERE",
  "status": "PRESENT",
  "notes": "Manual attendance marking by instructor"
}

###############################################################################
# 6. REAL-TIME WEBSOCKET TESTING
###############################################################################

### WebSocket Connection Test
# Use the WebSocket test panel:
# File: backend/services/realtime-service/test-websocket.html
# 
# Instructions:
# 1. Open test-websocket.html in your browser
# 2. Copy instructor or student token from above requests
# 3. Paste token in auth field and click "Save"
# 4. Click "Connect" to establish WebSocket connection
# 5. Use Course ID and Session ID from above requests
# 6. Click "Join Course Room" to monitor course events
# 7. Start session via API and watch real-time notifications
# 8. Mark attendance via API and watch real-time updates
#
# Real-time Events to Watch:
# - session:started (when session starts)
# - attendance:marked (when student marks attendance)
# - session:ended (when session ends)
# - course:joined (when student joins course)

###############################################################################
# 7. USER MANAGEMENT (ADMIN ONLY)
###############################################################################

### Get All Users (Admin)
GET {{attendanceApi}}/admin/users
Authorization: Bearer {{adminToken}}

### Get User by ID (Admin)
GET {{attendanceApi}}/admin/users/USER_ID_HERE
Authorization: Bearer {{adminToken}}

### Update User Role (Admin)
PUT {{attendanceApi}}/admin/users/USER_ID_HERE/role
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "role": "INSTRUCTOR"
}

### Deactivate User (Admin)
PUT {{attendanceApi}}/admin/users/USER_ID_HERE/deactivate
Authorization: Bearer {{adminToken}}

###############################################################################
# 8. SYSTEM ADMINISTRATION
###############################################################################

### Get System Statistics (Admin)
GET {{attendanceApi}}/admin/stats
Authorization: Bearer {{adminToken}}

### Get Active Sessions System-wide (Admin)
GET {{attendanceApi}}/admin/sessions/active
Authorization: Bearer {{adminToken}}

### Get Course Statistics (Admin)
GET {{attendanceApi}}/admin/courses/stats
Authorization: Bearer {{adminToken}}

