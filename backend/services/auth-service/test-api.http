POST http://localhost:3001/api/v1/auth/refresh-token
Content-Type: application/json

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhN2IwNzQ3NC1hYWY0LTQ4MGMtOWQ3YS04Y2NmMzkwZjVjMDgiLCJlbWFpbCI6InN0dWRlbnQxQGF0dGVuZGFuY2UuY29tIiwicm9sZSI6IlNUVURFTlQiLCJqdGkiOiI3NzQ2ZTk0NC0wOTEyLTQzZTEtYmMwZi0wNWZkNWQ2MzU4Y2UiLCJpYXQiOjE3NTYyNDgwNjcsImV4cCI6MTc1Njg1Mjg2N30.bsu1pJOetKKaJWZvqFQsQounW9B_gemAG3wyluVT-R0"
}

### Logout (Replace YOUR_ACCESS_TOKEN with actual token)
POST http://localhost:3001/api/v1/auth/logout
Authorization: Bearer YOUR_ACCESS_TOKEN

### Forgot Password
POST http://localhost:3001/api/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "student1@attendance.com"
}

### Change Password (Replace YOUR_ACCESS_TOKEN with actual token)
POST http://localhost:3001/api/v1/auth/change-password
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "currentPassword": "Student@123",
  "newPassword": "NewPass@123",
  "confirmPassword": "NewPass@123"
}

### Update Profile (Replace YOUR_ACCESS_TOKEN with actual token)
PUT http://localhost:3001/api/v1/auth/profile
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "firstName": "Updated",
  "lastName": "Name",
  "phoneNumber": "+9876543210"
}
