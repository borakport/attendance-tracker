### Health Check
GET http://localhost:3001/health

### Sign Up - New User
POST http://localhost:3001/api/v1/auth/signup
Content-Type: application/json

{
  "email": "newuser@example.com",
  "password": "Test@123",
  "confirmPassword": "Test@123",
  "firstName": "New",
  "lastName": "User",
  "phoneNumber": "+1234567890"
}

### Sign In - Student Account
POST http://localhost:3001/api/v1/auth/signin
Content-Type: application/json

{
  "email": "student1@attendance.com",
  "password": "NewPassword@123"
}

### Sign In - Instructor Account
POST http://localhost:3001/api/v1/auth/signin
Content-Type: application/json

{
  "email": "instructor@attendance.com",
  "password": "Instructor@123"
}

### Sign In - Admin Account
POST http://localhost:3001/api/v1/auth/signin
Content-Type: application/json

{
  "email": "admin@attendance.com",
  "password": "Admin@123"
}

### Get Profile (Replace YOUR_ACCESS_TOKEN with actual token from signin)
GET http://localhost:3001/api/v1/auth/profile
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhN2IwNzQ3NC1hYWY0LTQ4MGMtOWQ3YS04Y2NmMzkwZjVjMDgiLCJlbWFpbCI6InN0dWRlbnQxQGF0dGVuZGFuY2UuY29tIiwicm9sZSI6IlNUVURFTlQiLCJqdGkiOiJhOTRiNWM5YS00MmYwLTQ3ODMtOTQzNy0wYmFmYzQ1YjNmNjAiLCJpYXQiOjE3NTYzMDA1MTAsImV4cCI6MTc1NjMwMTQxMH0.vpnvaNBcfyfPboQLscokAUgCNFwqiNNn5XoaLBb0mzo

### Refresh Token (Replace YOUR_REFRESH_TOKEN with actual token from signin)
POST http://localhost:3001/api/v1/auth/refresh-token
Content-Type: application/json

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhN2IwNzQ3NC1hYWY0LTQ4MGMtOWQ3YS04Y2NmMzkwZjVjMDgiLCJlbWFpbCI6InN0dWRlbnQxQGF0dGVuZGFuY2UuY29tIiwicm9sZSI6IlNUVURFTlQiLCJqdGkiOiI3NzQ2ZTk0NC0wOTEyLTQzZTEtYmMwZi0wNWZkNWQ2MzU4Y2UiLCJpYXQiOjE3NTYyNDgwNjcsImV4cCI6MTc1Njg1Mjg2N30.bsu1pJOetKKaJWZvqFQsQounW9B_gemAG3wyluVT-R0"
}

### Logout (Replace YOUR_ACCESS_TOKEN with actual token)
POST http://localhost:3001/api/v1/auth/logout
Authorization: Bearer YOUR_ACCESS_TOKEN

### Forgot Password
POST http://localhost:3001/api/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "student1@attendance.com"
}

### Reset Password (Use token from forgot password logs)
POST http://localhost:3001/api/v1/auth/reset-password
Content-Type: application/json

{
  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhN2IwNzQ3NC1hYWY0LTQ4MGMtOWQ3YS04Y2NmMzkwZjVjMDgiLCJ0eXBlIjoicGFzc3dvcmRfcmVzZXQiLCJpYXQiOjE3NTYzMDQxNTAsImV4cCI6MTc1NjMwNzc1MH0.PA4O915qiW9KDG-gEfuD7E4ZIBEAwdvC3xNWsH0kNd0",
  "password": "Student@123",
  "confirmPassword": "Student@123"
}

### Change Password (Replace YOUR_ACCESS_TOKEN with actual token)
POST http://localhost:3001/api/v1/auth/change-password
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "currentPassword": "Student@123",
  "newPassword": "NewPass@123",
  "confirmPassword": "NewPass@123"
}

### Update Profile (Replace YOUR_ACCESS_TOKEN with actual token)
PUT http://localhost:3001/api/v1/auth/profile
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhN2IwNzQ3NC1hYWY0LTQ4MGMtOWQ3YS04Y2NmMzkwZjVjMDgiLCJlbWFpbCI6InN0dWRlbnQxQGF0dGVuZGFuY2UuY29tIiwicm9sZSI6IlNUVURFTlQiLCJqdGkiOiI3ZmRiYzI2My1hMjM0LTQ2NWYtYjEzNy1hNTU1ZjQwYTgwZjgiLCJpYXQiOjE3NTYzMDA2NjAsImV4cCI6MTc1NjMwMTU2MH0.GpqO4jXVK7nkHTebdy0enE0rUJr2vC6GmOYyef41CTA
Content-Type: application/json

{
  "firstName": "Updated",
  "lastName": "Name",
  "phoneNumber": "+9876543210"
}
