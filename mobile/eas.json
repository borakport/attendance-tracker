{
  "cli": {
    "version": ">= 7.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "18.18.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:3001/api/v1",
        "EXPO_PUBLIC_ATTENDANCE_API_URL": "http://10.0.2.2:3002/api/v1",
        "EXPO_PUBLIC_REALTIME_URL": "http://10.0.2.2:3003"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "env": {
          "EXPO_PUBLIC_ENV": "development"
        }
      },
      "ios": {
        "simulator": true,
        "buildConfiguration": "Debug"
      },
      "channel": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "preview"
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.gpsattendance.com/api/v1",
        "EXPO_PUBLIC_ATTENDANCE_API_URL": "https://attendance.gpsattendance.com/api/v1",
        "EXPO_PUBLIC_REALTIME_URL": "wss://realtime.gpsattendance.com"
      },
      "channel": "production"
    },
    "production-apk": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "http://your-server-ip:3001/api/v1",
        "EXPO_PUBLIC_ATTENDANCE_API_URL": "http://your-server-ip:3002/api/v1",
        "EXPO_PUBLIC_REALTIME_URL": "http://your-server-ip:3003"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      },
      "ios": {
        "appleId": "your-apple-id",
        "ascAppId": "your-asc-app-id",
        "appleTeamId": "your-team-id"
      }
    }
  }
}
